"use client";

/**
 * /terms — Terms & Conditions + Data Privacy Policy gate.
 *
 * Pixel-matched to the Infosys Assessment Platform consent screen:
 *   - Deep navy page background
 *   - Two collapsible cream cards: "Terms and Conditions" (v1.0.0) and
 *     "Data Privacy Policy" (v3.4.0). The first is expanded by default,
 *     the second collapsed — matches the screenshots.
 *   - A single agreement checkbox covering BOTH documents
 *   - A teal "Confirm" pill button, disabled until the box is ticked
 *
 * Wording is transcribed from the reference screenshots as closely as
 * legible. The Decline / Sign Out affordance lives as a subtle text link
 * in the header so the dark consent surface stays uncluttered, matching
 * the screenshots that show only "Confirm" at the bottom.
 */

import { useEffect, useState, type ReactNode } from "react";
import { useRouter } from "next/navigation";
import { useAuthStore } from "@/store/useAuthStore";

const TERMS_CLAUSES: string[] = [
  'IAP, including all Content present on IAP, is the property of Infosys Limited (hereinafter referred to as "Company") or the source from where the content is taken, and is copyrighted and protected by worldwide copyright laws and treaty provisions. The User hereby agrees to comply with all copyright laws worldwide in the use of IAP and to prevent any unauthorized copying of the Contents. Company does not grant any express or implied rights under any patents, trademarks, copyrights or trade secret information.',
  "The User shall not falsify or delete any copyright management information, such as author attributions, legal or other proper notices or proprietary designations or labels of the origin or source of software or other Content contained in a file that is uploaded.",
  "The User may not download, copy, distribute, transmit, display, perform, reproduce, duplicate, or publish, any information present on the IAP. Any unauthorized use of IAP or its contents shall lead to termination of the access granted by the Company.",
  "The User agrees to use IAP in accordance with the applicable rules, regulations, laws and policies of the Company.",
  "The User shall not reveal any personally identifiable data or sensitive personal information of his/her self or any other person.",
  "The User shall not in any manner reveal confidential or proprietary information of any third party.",
  "The User shall not transfer their rights to access to another person unless they have obtained explicit consent from the Company in writing to do so.",
  "The User shall acknowledge that the Company may, at its sole discretion, monitor, remove or edit any content that the User may contribute. Company may also pursue remedies available to it under law for any violation of these terms and conditions.",
  "Subject to the terms and conditions set forth in these Terms of Use, the Company grants the User a non-exclusive, non-transferable, limited right to access IAP and the Content therein. The User agrees not to interrupt or attempt to interrupt the operation of IAP in any manner.",
  "The Company reserves the right to change these terms and conditions at any time on its discretion. Your continued use of IAP after the posting of any amended terms and conditions shall constitute your agreement to be bound by any such changes.",
  "The User understand that IAP is an attempt by the Company to cater to the competency assessment needs of various stake holders in the company.",
  "The User gives his/her voluntary consent to download this Application on their personal device.",
];

function PolicyCard({
  title,
  version,
  defaultOpen,
  children,
}: {
  title: string;
  version: string;
  defaultOpen?: boolean;
  children: ReactNode;
}) {
  const [open, setOpen] = useState(!!defaultOpen);
  return (
    <section className="rounded-md bg-[#F4F1E8] shadow-[0_1px_2px_rgba(0,0,0,0.25)] overflow-hidden">
      <button
        type="button"
        onClick={() => setOpen((v) => !v)}
        className="w-full flex items-center justify-between px-6 py-3.5 text-left"
      >
        <h2 className="flex items-baseline gap-2">
          <span className="text-[17px] font-semibold text-[#0B1B4A]">
            {title}
          </span>
          <span className="text-[11px] font-normal text-[#5B6280]">
            Version: {version}
          </span>
        </h2>
        <svg
          className={"w-4 h-4 text-[#0B1B4A] transition-transform " + (open ? "rotate-180" : "")}
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          strokeWidth={2.2}
          strokeLinecap="round"
          strokeLinejoin="round"
        >
          <polyline points="6 12 10 8 14 12" />
        </svg>
      </button>
      {open && (
        <div className="px-6 pb-6 pt-0 text-[#0B1B4A]">{children}</div>
      )}
    </section>
  );
}

export default function TermsPage() {
  const router = useRouter();
  const user = useAuthStore((s) => s.user);
  const termsAccepted = useAuthStore((s) => s.termsAccepted);
  const acceptTerms = useAuthStore((s) => s.acceptTerms);
  const logout = useAuthStore((s) => s.logout);

  const [checked, setChecked] = useState(false);
  const [hydrated, setHydrated] = useState(false);
  useEffect(() => setHydrated(true), []);

  useEffect(() => {
    if (!hydrated) return;
    if (!user) router.replace("/login");
    else if (termsAccepted) router.replace("/");
  }, [hydrated, user, termsAccepted, router]);

  if (!hydrated || !user) {
    return (
      <div className="h-screen flex items-center justify-center bg-[#06091F] text-gray-400 text-sm">
        Loading...
      </div>
    );
  }

  const handleConfirm = () => {
    acceptTerms();
    router.replace("/");
  };

  // `logout` is intentionally kept on the store for future surfaces;
  // the consent screen no longer exposes a sign-out affordance per the
  // reference screenshots.
  void logout;

  const initials =
    user.name
      .split(/\s+/)
      .filter(Boolean)
      .slice(0, 2)
      .map((p) => (p[0] ? p[0].toUpperCase() : ""))
      .join("") || "U";

  const avatarTitle = user.name + " - " + user.candidateId;

  return (
    <div className="min-h-screen flex flex-col bg-[#06091F] text-white">
      <div className="h-14 px-4 flex items-center justify-between bg-[#06091F] border-b border-white/5">
        <div className="flex items-center gap-3">
          {/* Infosys Wingspan logo (left corner) */}
          {/* eslint-disable-next-line @next/next/no-img-element */}
          <img
            src="https://rec-test.infosys.com/iwa-web/assets/images/wingspan.svg"
            alt="Infosys Wingspan"
            className="h-8 w-auto"
          />
        </div>
        <div className="flex items-center gap-3">
          {/* Candidate avatar — white interior, teal ring, dark initials */}
          <div
            className="w-9 h-9 rounded-full flex items-center justify-center text-[12px] font-semibold text-[#0B1B4A] bg-white"
            style={{ boxShadow: "0 0 0 2px #26D9B5" }}
            title={avatarTitle}
          >
            {initials}
          </div>
        </div>
      </div>

      <main className="flex-1 px-6 py-8">
        <div className="max-w-5xl mx-auto space-y-4">
          <PolicyCard title="Terms and Conditions" version="1.0.0" defaultOpen>
            <p className="text-[13px] leading-relaxed text-[#0B1B4A] mb-3">
              The access and use of any information on the Infosys Assessment
              Platform (hereinafter referred to as{" "}
              <span className="font-semibold">&ldquo;IAP&rdquo;</span>) shall
              be governed by the following Terms of Use:
            </p>
            <ol className="space-y-2.5 text-[13px] leading-relaxed text-[#0B1B4A] list-none">
              {TERMS_CLAUSES.map((c, i) => (
                <li key={i} className="flex gap-3">
                  <span className="shrink-0 w-6 text-right">{i + 1}.</span>
                  <span className="flex-1">{c}</span>
                </li>
              ))}
            </ol>
          </PolicyCard>

          <PolicyCard title="Data Privacy Policy" version="3.4.0">
            <div className="text-[13px] leading-relaxed text-[#0B1B4A] space-y-3">
              <h3 className="text-center text-[14px] font-semibold tracking-wide pt-1">
                PRIVACY NOTICE
              </h3>
              <p className="text-[12px] text-[#3F4670]">
                Version 1.2 - Last Updated on 21-Dec-2023
              </p>

              <p>
                Infosys Limited, its subsidiaries, associates and affiliated
                companies (collectively referred to as &ldquo;Infosys&rdquo;,
                &ldquo;us&rdquo;, &ldquo;we&rdquo;) are committed to process
                your personal data as per the laws of your jurisdiction. We
                hereby notify you the following information about your
                personal data processing -
              </p>

              <p>
                <span className="font-semibold">
                  Personal data elements collected:
                </span>{" "}
                In view of the foregoing, Infosys would be required to collect
                the following Personal Data from you for the purposes as
                specified below:
              </p>
              <ol className="list-none space-y-2 pl-5">
                <li>
                  <span className="font-semibold">i.</span>{" "}
                  <span className="font-semibold">
                    For proctoring enabled Assessments (For non EU/EEA, UK
                    Candidates):
                  </span>{" "}
                  Your Personal Data such as: Full Name, Email ID, Password,
                  Scores and Results of your Assessment, Your facial image,
                  Face Descriptor (128-d embeddings for the face), Video
                  Anomaly Images, keystrokes anomalies (browser-related).
                </li>
                <li>
                  <span className="font-semibold">ii.</span>{" "}
                  <span className="font-semibold">
                    For proctoring enabled Assessments (For candidates in
                    EU/EEA, UK):
                  </span>{" "}
                  Your Personal Data such as: Full Name, Email ID, Password,
                  Scores and Results of your Assessment, Your facial image,
                  Video Anomaly Images, keystrokes anomalies (browser-related).
                </li>
              </ol>

              <p>
                <span className="font-semibold">
                  Data Recipients / Accessible to:
                </span>
              </p>
              <p>
                Your Personal Data will be accessible to certain authorized
                data recipients for the above processing of personal data
                which may include internal recipients within Infosys Ltd., its
                subsidiaries, or affiliates such as Recruitment, Education,
                Training and Assessment, Units/Org Leadership, our authorized
                service providers who may require access to the same for
                processing in relation to the above stated purpose(s),
                Auditors (internal/external), Infosys&apos; Clients (where
                applicable) based on contractual obligations, Government
                Bodies including statutory, regulatory authorities,
                law-enforcement agencies (as applicable), and any other
                parties expressly or impliedly authorized by you for receiving
                such disclosures.
              </p>

              <p>
                <span className="font-semibold">Lawfulness of Processing:</span>
              </p>
              <p>
                We process your Personal Data when it is necessary for the
                performance of a contract to which you are the party or in
                order to take steps at your request prior to entering into a
                contract or based on your consent as per applicable DP Laws.
                If you do not provide the Personal Data that we need in order
                to provide our services, we will not be able to provide our
                services to you. We process your Personal Data in the
                following circumstances:
              </p>
              <ul className="list-disc pl-6 space-y-1.5">
                <li>
                  To enable you to register on Infosys Internal Assessment
                  Platform.
                </li>
                <li>
                  <span className="font-semibold">
                    For non EU/EEA, UK Candidates
                  </span>{" "}
                  - To enable you to take online proctored assessment on our
                  internal platform which uses AI/ML Technology and to
                  shortlist you based on the data and assessment results.
                </li>
                <li>
                  <span className="font-semibold">
                    For candidates in EU/EEA, UK
                  </span>{" "}
                  - To enable you to take the exam where Online proctoring is
                  enabled (not solely based on automated decision making):
                  <ol className="list-none space-y-1.5 mt-1.5 pl-4">
                    <li>
                      <span className="font-semibold">i. Image anomaly</span>{" "}
                      - facial image will be processed (via machine learning
                      algorithms) using webcam for online video proctoring
                      purpose and checks for the following anomalies - (a)
                      Person not detected, (b) More than one face detected,
                      (c) Person not recognized, (d) Blank Screen detected -
                      (No texture detected), (e) Black Screen detected -
                      Image contains only black pixels, (f) Person looking
                      left or right (and not onto the screen), (g) Partial
                      face on the image. These Image anomalies (if any) will
                      be captured along with images captured on regular
                      interval(s) &amp; will be analyzed by authorized
                      Infosys admins for further action.
                    </li>
                    <li>
                      <span className="font-semibold">
                        ii. key-strokes anomalies
                      </span>{" "}
                      - the keystrokes that are entered by you where the
                      anomaly keys include tab shifts, cut, copy, paste,
                      Fullscreen, print screen, f1, f8, alt, right-click,
                      esc, window key.
                    </li>
                  </ol>
                </li>
                <li>
                  To enable Infosys to carry out recruitment related
                  activities.
                </li>
                <li>To send you mails regarding survey and feedbacks.</li>
              </ul>

              <p>
                <span className="font-semibold">
                  Your Rights (as per applicable DP laws):
                </span>
              </p>
              <p>
                You are entitled to exercise your rights as per applicable DP
                Laws by sending an email to{" "}
                <span className="underline">privacy@infosys.com</span>.
              </p>

              <p>
                <span className="font-semibold">Secondary Purpose</span>
              </p>
              <p>
                If we wish to use your personal data for a new purpose, not
                covered by this Notice, then we will provide you with a new
                notice explaining this new use prior to commencing the
                processing and setting out the relevant purposes and
                processing conditions. Where and whenever necessary, we will
                seek your prior consent to the new processing, unless
                authorized by law.
              </p>

              <p>
                <span className="font-semibold">
                  Data Transfer (International):
                </span>
              </p>
              <p>
                <span className="font-semibold">
                  For non-EU/EEA or UK Candidates:
                </span>{" "}
                If necessary, for the above stated purpose, the Personal Data
                listed above may be transferred to Infosys offices located in
                India, to our authorized vendor&apos;s servers located in
                India, to our auditors (where applicable) and to our clients
                (where applicable, as per contractual obligation). We have
                taken the necessary steps to ensure confidentiality and
                security of the transferred data. Your personal data is
                transferred outside your jurisdiction based on your consent /
                DTA / SCC, where applicable (based on applicable DP Laws).
              </p>
              <p>
                <span className="font-semibold">
                  For candidates in EU/EEA, UK:
                </span>{" "}
                Personal Data listed above may be transferred to countries
                located outside of the EU/EEA, UK, for which data protection
                legislation may differ from that of the EEA, i.e. our offices
                located globally and our third party service providers&apos;
                servers. We shall take the necessary steps to ensure
                confidentiality and security of the transferred data. We have
                in particular implemented the following safeguards: Standard
                Contractual Clauses (Art. 46 para. 2 lit. c) GDPR) and
                appropriate data transfer agreements, where applicable; the
                copies can be obtained by writing to{" "}
                <span className="underline">privacy@infosys.com</span>.
              </p>

              <p>
                <span className="font-semibold">Data Security:</span> Infosys
                adopts reasonable and appropriate security practices and
                procedures including administrative, physical security, and
                technical controls in order to safeguard your Personal Data.
              </p>

              <p>
                <span className="font-semibold">Data Retention:</span> Personal
                Data will not be retained for a period more than necessary to
                fulfill the purposes outlined in this Notice, unless a longer
                retention period is required by law or for directly related
                legitimate business purposes.
              </p>

              <p>
                <span className="font-semibold">
                  Contact your Local Data Protection Authority (as per
                  applicable DP Laws):
                </span>
              </p>
              <p>
                If you are unhappy with how we safeguard your personal data,
                you have the right to bring a complaint to your local data
                protection authority where applicable (as per applicable DP
                Laws).
              </p>

              <p>
                <span className="font-semibold">
                  Contact your Data Protection Officer:
                </span>{" "}
                If you have any queries, comments or requests, please contact
                our data protection officer,
              </p>
              <div className="pl-2">
                <p>Srinivas P, Data Protection Officer</p>
                <p>
                  Contact address: Data Privacy Office, Infosys Limited,
                  Electronics City, Hosur Road, Bangalore 560 100, India
                </p>
                <p>Phone: +91 80 2852 0261</p>
                <p>
                  Email:{" "}
                  <span className="underline">privacy@infosys.com</span>
                </p>
              </div>

              <p>
                By{" "}
                <span className="font-semibold">
                  clicking on the below button
                </span>{" "}
                you are confirming that you have read this Privacy Notice for
                Infosys to hold and process your personal data for the above
                purposes.
              </p>

              <p className="italic">
                <span className="font-semibold">
                  Additional Privacy Consent (for all Non-EU/EEA/UK Data
                  subjects belonging to jurisdictions where consent is
                  required for cross-border data transfer/data processing as
                  per applicable DP Laws):
                </span>{" "}
                By Clicking the below button, you also consent to the
                processing/transferring of your personal data outside your
                jurisdiction as mentioned in this Privacy Notice for the
                above purposes.
              </p>
            </div>
          </PolicyCard>

          <div className="pt-4 pb-2 flex flex-col items-center gap-5">
            <label className="flex items-center gap-2.5 text-[13px] text-white/90 cursor-pointer select-none">
              <span className="relative inline-flex items-center justify-center">
                <input
                  type="checkbox"
                  checked={checked}
                  onChange={(e) => setChecked(e.target.checked)}
                  className="peer sr-only"
                />
                <span
                  className={
                    "w-[18px] h-[18px] rounded-[3px] border transition-colors " +
                    (checked
                      ? "bg-[#26D9B5] border-[#26D9B5]"
                      : "bg-transparent border-white/40")
                  }
                />
                {checked && (
                  <svg
                    className="absolute w-3 h-3 text-[#06091F]"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    strokeWidth={3}
                    strokeLinecap="round"
                    strokeLinejoin="round"
                  >
                    <polyline points="3 8 7 12 13 4" />
                  </svg>
                )}
              </span>
              I have read and agree to the Terms and Conditions, Data Privacy
              Policy
            </label>

            <button
              onClick={handleConfirm}
              disabled={!checked}
              className={
                "h-11 px-10 rounded-md text-[14px] font-semibold transition-colors " +
                (checked
                  ? "bg-[#26D9B5] text-[#06091F] hover:bg-[#3BE6C4] cursor-pointer"
                  : "bg-[#26D9B5]/40 text-[#06091F]/60 cursor-not-allowed")
              }
            >
              Confirm
            </button>
          </div>
        </div>
      </main>
    </div>
  );
}
